<script>
    // --- DOM Elements ---
    const terminalInput = document.getElementById('terminal-input');
    const commandLog = document.getElementById('command-log');
    const gameGridDisplay = document.getElementById('game-grid'); // NEW: Reference to the game grid display

    // --- Game State & Command History ---
    const commandHistory = [];
    let historyIndex = 0;

    // Global game state object
    let gameState = {
        connectedNode: null,       // Stores the name of the currently connected node
        discoveredNodes: [],     // Array of node names found by 'scan'
        // Add more state variables here as your game grows (e.g., inventory: [], score: 0)
    };

    // Variable to hold the reference to the "Processing..." log entry
    let processingLogEntry = null;

    // --- Command Definitions ---
    const commandMap = {
        help: {
            description: "Lists all available commands.",
            execute: (args) => {
                const commandList = Object.keys(commandMap).map(cmd => 
                    `  ${cmd.padEnd(10)} - ${commandMap[cmd].description}`
                ).join('\n');
                logCommand(`Available commands:\n${commandList}`, 'system');
            }
        },
        scan: {
            description: "Scans the network for activity.",
            execute: (args) => {
                showProcessing(`Initializing network scanner...`); 
                terminalInput.disabled = true;
                terminalInput.placeholder = "Scanning network...";

                // Define a pool of potential nodes
                const potentialNodes = [
                    { name: "NEXUS-01", status: "Online", ping: "23ms", security: "Medium" },
                    { name: "DATA-VAULT-7", status: "Online", ping: "45ms", security: "High" },
                    { name: "PROXY-ALPHA", status: "Online", ping: "12ms", security: "Low" },
                    { name: "ARCHIVE-HUB", status: "Offline", ping: "N/A", security: "N/A" },
                    { name: "SEC-SERVER-03", status: "Online", ping: "38ms", security: "Very High" },
                    { name: "DEBUG-CONSOLE", status: "Online", ping: "7ms", security: "Minimal" }
                ];

                // Randomly select a few nodes to "find"
                const foundNodes = [];
                // Ensure at least 3 nodes, up to 5
                const numberOfNodesToFind = Math.floor(Math.random() * 3) + 3; // 3, 4, or 5
                
                // Shuffle the array and pick the first 'numberOfNodesToFind'
                potentialNodes.sort(() => 0.5 - Math.random());
                for (let i = 0; i < numberOfNodesToFind && i < potentialNodes.length; i++) {
                    foundNodes.push(potentialNodes[i]);
                }

                // Randomize scan time slightly
                const scanTime = Math.floor(Math.random() * 1500) + 2000; // Between 2 and 3.5 seconds

                setTimeout(() => {
                    if (foundNodes.length > 0) {
                        let results = `Scan complete. Found ${foundNodes.length} active nodes:\n`;
                        foundNodes.forEach(node => {
                            results += `  - [${node.name}] Status: ${node.status}, Ping: ${node.ping}, Security: ${node.security}\n`;
                            // Store discovered nodes in game state only if they are online and not already discovered
                            if (node.status === "Online" && !gameState.discoveredNodes.includes(node.name)) {
                                gameState.discoveredNodes.push(node.name);
                            }
                        });
                        logCommand(results.trim(), 'system'); // Use trim to remove trailing newline
                    } else {
                        logCommand("Scan complete. No active nodes detected at this time.", 'system');
                    }
                    
                    hideProcessing();
                    terminalInput.disabled = false;
                    terminalInput.placeholder = "Enter command...";
                    terminalInput.focus();
                }, scanTime); // Use randomized scan time
            }
        },
        use: {
            description: "Executes a script. Usage: use <script_name>",
            execute: (args) => {
                if (args.length > 0) {
                    logCommand(`Executing script: ${args[0]}...`, 'system');
                    // Future logic for using scripts would go here, possibly checking gameState.inventory
                } else {
                    logCommand("A script name is required. Usage: use <script_name>", 'error');
                }
            }
        },
        clear: {
            description: "Clears the system log.",
            execute: (args) => {
                commandLog.innerHTML = '';
                // Re-add initial message after clear
                logCommand("> System initialized. Welcome, Ghost. Type 'help' for a list of commands.", 'system');
            }
        },
        connect: {
            description: "Connects to a target node. Usage: connect <node_name>",
            execute: (args) => {
                const targetNode = args[0] ? args[0].toUpperCase() : null; // Ensure uppercase for comparison
                
                if (targetNode) {
                    // Check if the node has been discovered AND is not the current connected node
                    if (gameState.discoveredNodes.includes(targetNode) && gameState.connectedNode !== targetNode) {
                        showProcessing(`Attempting to establish uplink to ${targetNode}...`);
                        terminalInput.disabled = true;
                        terminalInput.placeholder = `Connecting to ${targetNode}...`;

                        setTimeout(() => {
                            gameState.connectedNode = targetNode; // Set the connected node in state
                            logCommand(`Connection to ${targetNode} successful. You are now connected.`, 'system');
                            hideProcessing();
                            terminalInput.disabled = false;
                            terminalInput.placeholder = "Enter command...";
                            terminalInput.focus();
                            // Update the main game-grid display
                            gameGridDisplay.innerHTML = `<p class="cyan-glow text-3xl">CONNECTED TO: ${gameState.connectedNode}</p>`;
                        }, 1500);
                    } else if (gameState.connectedNode === targetNode) {
                        logCommand(`Already connected to ${targetNode}.`, 'system');
                    }
                    else {
                        logCommand(`Node '${targetNode}' not found or not yet discovered. Try 'scan'.`, 'error');
                    }
                } else {
                     logCommand("A target node is required. Usage: connect <node_name>", 'error');
                }
            }
        },
        disconnect: { // NEW COMMAND: Disconnect
            description: "Disconnects from the current node.",
            execute: (args) => {
                if (gameState.connectedNode) {
                    logCommand(`Disconnecting from ${gameState.connectedNode}...`, 'system');
                    gameState.connectedNode = null; // Clear the connected node
                    logCommand("Disconnected. Awaiting Uplink...", 'system');
                    gameGridDisplay.innerHTML = `<p class="text-gray-600 text-2xl">Awaiting Uplink...</p>`;
                } else {
                    logCommand("Not currently connected to any node.", 'error');
                }
            }
        },
        status: { // NEW COMMAND: Status
            description: "Displays current system status and connected node.",
            execute: (args) => {
                let statusMessage = "SYSTEM STATUS:\n";
                statusMessage += `  - Connected Node: ${gameState.connectedNode ? gameState.connectedNode : "None"}\n`;
                statusMessage += `  - Discovered Nodes: ${gameState.discoveredNodes.length > 0 ? gameState.discoveredNodes.join(', ') : "None"}\n`;
                // You can add more status info here like power, signal, etc.
                logCommand(statusMessage.trim(), 'system');
            }
        }
    };

    // --- Event Listener for the console ---
    terminalInput.addEventListener('keydown', function(event) {
        const command = terminalInput.value.trim();

        // --- Enter Key ---
        if (event.key === 'Enter' && command !== '') {
            logCommand(command, 'user');
            processCommand(command);
            
            // Add command to history and reset index
            commandHistory.push(command);
            historyIndex = commandHistory.length;
            terminalInput.value = '';
        } 
        // --- Arrow Up Key ---
        else if (event.key === 'ArrowUp') {
            event.preventDefault(); // Prevent cursor from jumping
            if (historyIndex > 0) {
                historyIndex--;
                terminalInput.value = commandHistory[historyIndex];
                // Move cursor to end of the line
                terminalInput.setSelectionRange(terminalInput.value.length, terminalInput.value.length);
            }
        } 
        // --- Arrow Down Key ---
        else if (event.key === 'ArrowDown') {
            event.preventDefault();
            if (historyIndex < commandHistory.length - 1) {
                historyIndex++;
                terminalInput.value = commandHistory[historyIndex];
                terminalInput.setSelectionRange(terminalInput.value.length, terminalInput.value.length);
            } else {
                // If we are at the end, clear the input
                historyIndex = commandHistory.length;
                terminalInput.value = '';
            }
        }
    });

    /**
     * Adds a new entry to the command log UI.
     * @param {string} text - The text to log.
     * @param {string} [type='user'] - The type of log entry ('user', 'system', 'error').
     * @param {boolean} [isProcessing=false] - If true, this log entry can be removed later.
     */
    function logCommand(text, type = 'user', isProcessing = false) {
        const entry = document.createElement('div');
        entry.classList.add('log-entry');

        switch(type) {
            case 'system':
                entry.classList.add('text-green-400');
                entry.textContent = `[SYSTEM] ${text}`;
                break;
            case 'error':
                entry.classList.add('text-red-500');
                entry.textContent = `[ERROR] ${text}`;
                break;
            case 'user':
            default:
                entry.classList.add('text-cyan-400');
                entry.textContent = `> ${text}`;
                break;
        }
        
        // Add to the top of the log
        commandLog.insertBefore(entry, commandLog.firstChild);
        if (isProcessing) {
            processingLogEntry = entry; // Save reference to this entry
        }
    }

    /**
     * Shows a temporary processing message in the log.
     * @param {string} message - The message to display.
     */
    function showProcessing(message) {
        if (processingLogEntry) {
            hideProcessing(); // Ensure any previous processing message is cleared
        }
        logCommand(message, 'system', true); // Log it as a system message and mark it for removal
    }

    /**
     * Hides and removes the temporary processing message from the log.
     */
    function hideProcessing() {
        if (processingLogEntry && processingLogEntry.parentNode === commandLog) {
            commandLog.removeChild(processingLogEntry);
        }
        processingLogEntry = null; // Clear the reference
    }

    /**
     * Processes the command entered by the user using the commandMap.
     * @param {string} command - The command to process.
     */
    function processCommand(command) {
        const parts = command.toLowerCase().split(' ');
        const primaryAction = parts[0];
        const args = parts.slice(1);

        if (commandMap[primaryAction]) {
            commandMap[primaryAction].execute(args);
        } else {
            logCommand(`Command not recognized: '${primaryAction}'. Type 'help' for a list of commands.`, 'error');
        }
    }

    // --- Initial focus on the input field ---
    terminalInput.focus();

</script>
